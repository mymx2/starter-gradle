{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/package.json",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.8.0"
  },
  "scripts": {
    "debug": "cross-env CI=false DEBUG=* node index.ts",
    "dev": "node index.ts",
    "clean": "rimraf node_modules",
    "lint": "eslint . --cache-location node_modules/.cache/eslint/",
    "fix": "eslint . --fix",
    "up": "taze major -I",
    "_ni": "npm i -g pnpm @antfu/ni && pnpm i --force"
  },
  "dependencies": {
    "@actions/artifact": "catalog:",
    "@actions/attest": "catalog:",
    "@actions/cache": "catalog:",
    "@actions/core": "catalog:",
    "@actions/exec": "catalog:",
    "@actions/github": "catalog:",
    "@actions/glob": "catalog:",
    "@actions/http-client": "catalog:",
    "@actions/io": "catalog:",
    "@actions/tool-cache": "catalog:",
    "@antfu/utils": "catalog:",
    "@octokit/action": "catalog:",
    "cross-env": "catalog:",
    "es-toolkit": "catalog:",
    "execa": "catalog:",
    "fs-extra": "catalog:",
    "kleur": "catalog:",
    "octokit": "catalog:",
    "ofetch": "catalog:",
    "rimraf": "catalog:"
  },
  "devDependencies": {
    "@actions/expressions": "catalog:",
    "@actions/languageservice": "catalog:",
    "@actions/workflow-parser": "catalog:",
    "@antfu/eslint-config": "catalog:",
    "@octokit/openapi-types": "catalog:",
    "@octokit/types": "catalog:",
    "@octokit/webhooks-definitions": "catalog:",
    "@types/debug": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "baseline-browser-mapping": "catalog:",
    "cypress": "catalog:",
    "debug": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-cypress": "catalog:",
    "eslint-plugin-format": "catalog:",
    "minimatch": "catalog:",
    "prettier": "catalog:",
    "taze": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
